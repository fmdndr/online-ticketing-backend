{
  "Serilog": {
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "https://prod.socratic-event.com",
      "https://socratic-event.com",
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://catalog-api:8080"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket-api": {
            "Address": "http://basket-api:8080"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-api": {
            "Address": "http://payment-api:8080"
          }
        }
      }
    }
  }
}
