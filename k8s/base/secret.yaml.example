apiVersion: v1
kind: Secret
metadata:
  name: ticketing-secrets
  labels:
    app.kubernetes.io/part-of: ticketing
type: Opaque
# ============================================================================
# IMPORTANT: Replace placeholder values before deploying.
# In production, manage via Rancher UI / Sealed Secrets / External Secrets.
# ============================================================================
stringData:
  ConnectionStrings__PaymentDb: "Host=REMOTE_POSTGRES_IP;Port=5432;Database=ticketing_payments;Username=REMOTE_POSTGRES_USER;Password=REMOTE_POSTGRES_PASSWORD"
  ConnectionStrings__IdentityDb: "Host=REMOTE_POSTGRES_IP;Port=5432;Database=ticketing_identity;Username=REMOTE_POSTGRES_USER;Password=REMOTE_POSTGRES_PASSWORD"
  DatabaseSettings__ConnectionString: "mongodb://mongo:27017"
